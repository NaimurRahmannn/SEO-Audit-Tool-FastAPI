# ---- Backend ----
# SQLAlchemy/psycopg connection string for Postgres
DATABASE_URL=postgresql+psycopg://seo:seo@localhost:5432/seo_audit
# Google PageSpeed Insights API key (optional for now)
PSI_API_KEY=your-psi-api-key
